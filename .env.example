# Partnership Architecture — Environment Variables
# Copy this to .env and fill in your values.
# The setup wizard (npm run setup) does this for you.

# === PATH A: Claude Code ===
# No API key needed here — Claude Code authenticates via your Anthropic account.
# Just run: claude

# === PATH B: AlienKind CLI ===
# Your LLM API key — at least one of these:
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# Or any gateway/proxy key (Vercel AI Gateway, LiteLLM, etc.):
# AI_GATEWAY_API_KEY=

# === HEAVILY RECOMMENDED — Supabase ===
# Your partner works without Supabase (local files), but growth tracking,
# multi-terminal awareness, and nightly evolution all require it.
# Free tier covers everything: https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# === OPTIONAL — Local Models (Tier 2: Pursuit of Sovereignty) ===
# CLASSIFIER_HOST=http://localhost
# CLASSIFIER_PORT=[PORT_CLASSIFIER]
# LOCAL_HOST=http://localhost:[PORT_DAILY]

# === OPTIONAL — Multi-instance coordination ===
# Requires Supabase. Without it, single-terminal only.
# ALIENKIND_TERMINAL_ID=   (auto-generated if not set)
#
# NOTE: the ALIENKIND_* prefix is the reference name. When you deploy your
# own partner instance, rename this prefix to match your partner's identity
# (e.g., MYAGENT_TERMINAL_ID, CONN_TERMINAL_ID). The prefix appears across
# env vars, /tmp/ paths, and internal references. Keep it consistent with
# your partner's name — a partner-specific prefix avoids collisions when
# multiple partners run on the same machine and makes the codebase read
# as distinctly yours.
#
# Other ALIENKIND_* env vars (set automatically by daemon.ts for forked jobs,
# rarely set manually):
#   ALIENKIND_SESSION_MODE         — containment field (analyst/operator/builder)
#   ALIENKIND_SESSION_CHANNEL      — which session channel a job belongs to
#   ALIENKIND_DAEMON_SESSION_ID    — daemon's session ID for the job
#   ALIENKIND_RECOVERY_DATE/TYPE   — recovery mode context
