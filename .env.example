# AlienKind — environment configuration template
# Copy to .env and fill in. Never commit .env.

# ─── Substrate (pick one) ─────────────────────────────────────────────
# Anthropic API key (Claude Code subscription users: leave blank, use the CLI)
ANTHROPIC_API_KEY=

# OpenRouter — has a free tier with DeepSeek R1
OPENROUTER_API_KEY=

# OpenAI — direct API
OPENAI_API_KEY=

# Generic OpenAI-compatible endpoint (Vercel AI Gateway, local Ollama, etc.)
OPENAI_API_BASE=
OPENAI_MODEL=

# ─── Data core (Supabase) ─────────────────────────────────────────────
# Free tier works to start. Pro tier ($25/mo) recommended for production partners.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Optional: local fallbacks ────────────────────────────────────────
# AlienKind degrades gracefully: Supabase → SQLite → file. No setup needed
# unless you want a specific local path:
ALIENKIND_SQLITE_PATH=
ALIENKIND_FILE_STORE_PATH=

# ─── Partner identity ─────────────────────────────────────────────────
# Name your partner. Optional — set via /name in chat if you'd rather
# decide as you go.
PARTNER_NAME=
