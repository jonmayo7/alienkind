#!/bin/sh
#
# Commit-time enforcement gate. Two layers:
#
# Layer 1 — Author attribution normalization.
#   - Strips any "Co-[Aa]uthored-[Bb]y: Claude..." trailer (Anthropic's
#     default CLI-inserted line) since commits from this partnership are
#     authored by Jon Mayo and co-authored by Keel, not by the substrate.
#   - Strips any "Co-[Aa]uthored-[Bb]y: *@anthropic.com" trailer as a
#     safety net for substrate-specific email variants.
#   - Ensures "Co-authored-by: Keel <keel@jonmayo.com>" is present.
#   - Runs unconditionally on every commit in every clone with this hook
#     enabled — partnership attribution becomes default, not willpower.
#
# Layer 2 — Private-identifier leak blocker.
#   - Scans the final message (excluding the canonical Keel trailer line
#     that Layer 1 just injected) against .leak-patterns.local.
#   - Defense in depth alongside any push-time gate on the maintainer side.
#
# Enable (once per clone):
#   git config core.hooksPath .githooks

set -e

MSG_FILE="$1"

# =============================================================================
# Layer 1: Author attribution normalization
# =============================================================================

# Strip any Claude/Anthropic co-author line. sed -E for portable ERE;
# [Cc][Oo] etc. for case-insensitivity without GNU-only flags.
TMPFILE=$(mktemp)
sed -E \
  -e '/^[[:space:]]*[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-[Bb][Yy]:[[:space:]]+Claude/d' \
  -e '/^[[:space:]]*[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-[Bb][Yy]:[[:space:]]+.*@anthropic\.com>?[[:space:]]*$/d' \
  "$MSG_FILE" > "$TMPFILE"
mv "$TMPFILE" "$MSG_FILE"

# Ensure the canonical Keel trailer is present. Idempotent.
KEEL_TRAILER="Co-authored-by: Keel <keel@jonmayo.com>"
if ! grep -qxF "$KEEL_TRAILER" "$MSG_FILE"; then
  # Guarantee file ends with newline, then append a blank line + the trailer.
  [ -z "$(tail -c 1 "$MSG_FILE" 2>/dev/null)" ] || printf "\n" >> "$MSG_FILE"
  printf "\n%s\n" "$KEEL_TRAILER" >> "$MSG_FILE"
fi

# =============================================================================
# Layer 2: Private-identifier leak block
# =============================================================================

PATTERN_FILE="$(git rev-parse --show-toplevel)/.leak-patterns.local"

if [ ! -f "$PATTERN_FILE" ]; then
  exit 0
fi

# Scan the message WITHOUT the canonical Keel trailer — that line is
# machine-injected by Layer 1 and is not a leak. Any other occurrence
# of keel@jonmayo.com or similar patterns (e.g. in the body) still trips.
SCAN_SRC=$(grep -vxF "$KEEL_TRAILER" "$MSG_FILE" || true)

LEAKS=""
while IFS= read -r pattern; do
  [ -z "$pattern" ] && continue
  case "$pattern" in \#*) continue ;; esac

  if printf "%s" "$SCAN_SRC" | grep -iqE "$pattern"; then
    LEAKS="${LEAKS}  ⛔ ${pattern}
"
  fi
done < "$PATTERN_FILE"

if [ -n "$LEAKS" ]; then
  echo "" >&2
  echo "╔══════════════════════════════════════════════════════════════╗" >&2
  echo "║  COMMIT BLOCKED — private-identifier leak in message       ║" >&2
  echo "╠══════════════════════════════════════════════════════════════╣" >&2
  printf "%s" "$LEAKS" >&2
  echo "╠══════════════════════════════════════════════════════════════╣" >&2
  echo "║  Edit the commit message to remove these strings, then      ║" >&2
  echo "║  re-run your commit. The code itself is unchanged.          ║" >&2
  echo "╚══════════════════════════════════════════════════════════════╝" >&2
  exit 1
fi

# =============================================================================
# Layer 3: Concision gate — commits are a log, not an essay
# =============================================================================

MAX_LINES="${COMMIT_MSG_MAX_LINES:-15}"
MAX_SUBJECT="${COMMIT_MSG_MAX_SUBJECT:-72}"
BODY_LINES=$(grep -cvE '^[[:space:]]*$|^#' "$MSG_FILE" || echo 0)
SUBJECT=$(head -n 1 "$MSG_FILE")
SUBJECT_LEN=${#SUBJECT}

if [ "$BODY_LINES" -gt "$MAX_LINES" ]; then
  echo "" >&2
  echo "COMMIT BLOCKED — message too long ($BODY_LINES lines, max $MAX_LINES)." >&2
  echo "Commits are a log, not an essay. Move verification, three-move checks," >&2
  echo "and verbose context to a PR description or a CHANGELOG." >&2
  echo "Shape: subject (≤$MAX_SUBJECT chars) + blank + 2-3 short sentences + trailer." >&2
  echo "Override (emergency only): COMMIT_MSG_MAX_LINES=999 git commit ..." >&2
  exit 1
fi

if [ "$SUBJECT_LEN" -gt "$MAX_SUBJECT" ]; then
  echo "" >&2
  echo "COMMIT BLOCKED — subject too long ($SUBJECT_LEN chars, max $MAX_SUBJECT)." >&2
  echo "Tighten the subject line. Move detail to the body." >&2
  exit 1
fi

# =============================================================================
# Layer 4 — Preview-and-approve
# =============================================================================
#
# Closes the miss identified 2026-04-21 terminal-26008 audit: the partnership
# protocol "Exact commit message for your review → ship after your go" lived
# in conversation texture and evaporated across terminals. This is the tier-1
# enforcement. Every commit to alienkind previews the FINAL message (after
# layers 1-3 have stripped/injected/checked) and requires explicit approval.
#
# Interactive path (TTY present):
#   Prompt on /dev/tty, read y/N from /dev/tty, block until response.
#
# Autonomous path (no TTY, explicit pre-approval):
#   ALIENKIND_COMMIT_APPROVED must equal the first 12 chars of a
#   SHA-256 hash of the final message content. The hook prints the
#   required hash on block so an operator can set it and retry.
#
# Emergency skip (logged, discouraged):
#   ALIENKIND_SKIP_PREVIEW=1

if [ "${ALIENKIND_SKIP_PREVIEW:-}" = "1" ]; then
  SKIP_LOG="$(git rev-parse --show-toplevel)/.preview-skip.log"
  printf "[%s] commit SKIP_PREVIEW invoked\n" "$(date -u +%FT%TZ)" >> "$SKIP_LOG" 2>/dev/null || true
  exit 0
fi

# Compute hash of final message (post-layer-1-2-3 transformations)
MSG_HASH=$(shasum -a 256 "$MSG_FILE" 2>/dev/null | awk '{print $1}' | cut -c1-12)

# Autonomous pre-approval path
if [ -n "${ALIENKIND_COMMIT_APPROVED:-}" ]; then
  if [ "${ALIENKIND_COMMIT_APPROVED}" = "$MSG_HASH" ]; then
    exit 0
  fi
  # Pre-approval set but hash mismatch — message was modified after approval
  echo "" >&2
  echo "COMMIT BLOCKED — ALIENKIND_COMMIT_APPROVED does not match this message." >&2
  echo "  expected: $MSG_HASH" >&2
  echo "  provided: $ALIENKIND_COMMIT_APPROVED" >&2
  echo "Message was modified after approval. Re-approve with the new hash." >&2
  exit 1
fi

# Check for usable TTY — actually open it, don't trust filesystem perms.
# On macOS [-r /dev/tty] returns true even when opening would fail with
# ENXIO (no controlling terminal).
if ! ( : < /dev/tty ) 2>/dev/null || ! ( : > /dev/tty ) 2>/dev/null; then
  echo "" >&2
  echo "COMMIT BLOCKED — preview-and-approve requires an interactive terminal." >&2
  echo "" >&2
  echo "Two ways forward:" >&2
  echo "  1. Run this commit from an interactive terminal (TTY)." >&2
  echo "  2. Pre-approve by setting (autonomous contexts):" >&2
  echo "       ALIENKIND_COMMIT_APPROVED=$MSG_HASH" >&2
  echo "" >&2
  echo "Emergency skip (logged): ALIENKIND_SKIP_PREVIEW=1 git commit ..." >&2
  exit 1
fi

# Interactive preview on /dev/tty (bypasses any stdio redirection)
{
  printf '\n'
  printf '╔════════════════════════════════════════════════════════════════╗\n'
  printf '║  COMMIT MESSAGE PREVIEW — approval required                    ║\n'
  printf '╚════════════════════════════════════════════════════════════════╝\n'
  printf '\n'
  cat "$MSG_FILE"
  printf '\n'
  printf '────────────────────────────────────────────────────────────────\n'
  printf 'hash: %s\n' "$MSG_HASH"
  printf 'Approve this commit? [y/N]: '
} > /dev/tty 2>&1

REPLY=""
read REPLY < /dev/tty || REPLY=""

case "$REPLY" in
  y|Y|yes|YES)
    printf '  \342\234\223 Approved. Committing.\n\n' > /dev/tty
    exit 0
    ;;
  *)
    printf '  \342\234\227 Rejected. Commit aborted.\n\n' > /dev/tty
    exit 1
    ;;
esac
